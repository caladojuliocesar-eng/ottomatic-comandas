# Configurações do Firebase para o Novo Cliente
# Copie este arquivo como `.env.local` e preencha as credenciais.
# Na Vercel, cadastre estas chaves no painel "Environment Variables".

VITE_FIREBASE_API_KEY=insira_aqui_sua_api_key
VITE_FIREBASE_AUTH_DOMAIN=exemplo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=exemplo
VITE_FIREBASE_STORAGE_BUCKET=exemplo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:1234abcd5678efgh
